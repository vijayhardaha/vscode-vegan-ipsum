# ==========================================
# GITIGNORE CONFIGURATION FILE
# ==========================================
# Purpose: Specifies files and directories that should be ignored by Git.
# Docs: https://git-scm.com/docs/gitignore
# ==========================================

# ==========================================
# IDE CONFIGURATION FILES
# ==========================================
# Ignore IDE-specific settings and metadata.
.idea/

# ==========================================
# DEPENDENCIES
# ==========================================
# Ignore dependency directories.
/node_modules

# ==========================================
# TESTING OUTPUT
# ==========================================
# Ignore coverage reports generated during testing.
/coverage

# ==========================================
# PRODUCTION OUTPUT
# ==========================================
# Ignore build artifacts and production directories.
/dist
/typings

# ==========================================
# MISCELLANEOUS
# ==========================================
# Ignore system-specific files and logs.
.DS_Store
.Thumbnails

# ==========================================
# LOG FILES
# ==========================================
# Ignore log files generated by npm and Yarn.
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==========================================
# TYPESCRIPT
# ==========================================
# Ignore TypeScript build info files.
typings
*.tsbuildinfo

# ==========================================
# ENVIRONMENT VARIABLES
# ==========================================
# Ignore environment variable files.
.env
.env.local
