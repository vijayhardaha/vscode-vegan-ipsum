{
  "name": "vegan-ipsum",
  "displayName": "Vegan Ipsum",
  "description": "Generates and inserts vegan ipsum text",
  "version": "1.0.2",
  "icon": "images/icon.png",
  "scripts": {
    "compile": "webpack",
    "dev": "webpack --watch",
    "build": "webpack --mode production --devtool hidden-source-map",
    "lint": "eslint --ext .js,.mjs .",
    "lint:fix": "eslint --ext .js,.mjs --fix . ",
    "format": "prettier --write \"**/*.{js,mjs,json,md,yml}\"",
    "format:check": "prettier --check \"**/*.{js,mjs,json,md,yml}\"",
    "prepare": "husky"
  },
  "homepage": "https://github.com/vijayhardaha/vscode-vegan-ipsum",
  "repository": {
    "type": "git",
    "url": "https://github.com/vijayhardaha/vscode-vegan-ipsum"
  },
  "bugs": {
    "url": "https://github.com/vijayhardaha/vscode-vegan-ipsum/issues"
  },
  "license": "MIT",
  "publisher": "vijayhardaha",
  "author": {
    "name": "Vijay Hardaha",
    "url": "https://github.com/vijayhardaha/"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Snippets"
  ],
  "keywords": [
    "vegan ipsum",
    "lorem ipsum",
    "placeholder",
    "dummy text",
    "vegan",
    "text generator",
    "dummy text generator"
  ],
  "main": "./src/extension.js",
  "browser": "./dist/web/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vegan-ipsum.line",
        "title": "Vegan Ipsum: Insert a line"
      },
      {
        "command": "vegan-ipsum.paragraph",
        "title": "Vegan Ipsum: Insert a paragraph"
      },
      {
        "command": "vegan-ipsum.multipleParagraphs",
        "title": "Vegan Ipsum: Insert multiple paragraphs"
      }
    ]
  },
  "dependencies": {
    "vegan-ipsum": "^2.0.1"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.28.6",
    "@babel/preset-env": "^7.29.2",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/compat": "^2.0.4",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@types/vscode": "^1.110.0",
    "@types/webpack-env": "^1.18.8",
    "@typescript-eslint/parser": "^8.58.0",
    "@vijayhardaha/dev-config": "^1.0.10",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  }
}
